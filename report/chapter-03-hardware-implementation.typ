        s_j + p dot "dist"_(i,j) dot "II" >= s_i + L_i
      $
      $
        sum_(k t in S) sum_(i in V) u_(i,r) x_(k t,i) <= c_r quad "若启用模调度"
      $
      $
        sum_(i in V) u_(i,r) x_(s,i) <= c_r quad "若未启用模调度"
      $
      $
        s_j + p dot "dist"_(i,j) dot "II" - s_i - L_i <= l_i
      $
      $
        s_i in R_i, quad sum_(s in S) x_(s,i) = 1, quad M >= s_i + L_i
      $
    ]
  ]
]

#figure(
