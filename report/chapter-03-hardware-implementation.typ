    table.header([符号], [含义]),
      [${m_i}$], [饱和等价图中的映射等价节点集合],
      [${"cls"_j}$], [饱和等价图中的等价类集合],
      [$"cls"_"root"$], [表示整个程序输出的根等价类],
      [$m_k in "cls"_j$], [等价类 $"cls"_j$ 包含映射等价节点 $m_k$],
      [$"child"(m_i)$], [映射等价节点 $m_i$ 的子等价类集合],
      [$f_"cls_j", b_"cls_j"$], [等价类的完成时间 / 是否被选中],
      [$s_"m_i", f_"m_i" , b_"m_i"$], [映射等价节点的开始时间 / 完成时间 / 是否被选中],
